# Copy this to .env and fill in your values.
# NEVER commit .env to git.

# OpenAI API key — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Gmail address that SENDS the email (must match the App Password below)
GMAIL_SENDER=youremail@gmail.com

# Gmail App Password — NOT your regular password.
# Enable 2FA first, then generate at:
# https://myaccount.google.com/apppasswords
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Email address that RECEIVES the weekly digest
RECIPIENT_EMAIL=youremail@gmail.com
